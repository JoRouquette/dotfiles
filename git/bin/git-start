#!/usr/bin/env bash
# git-start [feature|fix|release|hotfix] <name> [--target <base>]
#   Crée une branche en respectant les conventions git-flow :
#     feature/<name>, fix/<name>  → basé sur develop
#     release/<name>              → basé sur develop, préfixé devops/
#     hotfix/<name>               → basé sur main

set -euo pipefail
source "$(dirname "$(readlink -f "$0")")/../lib/wt-common.sh"

BASE_DEV="develop"
BASE_PROD="main"
TARGET_OVERRIDE=""
TYPE=""
NAME=""

while [ $# -gt 0 ]; do
    case "$1" in
        --target)                 shift; TARGET_OVERRIDE="$1" ;;
        feature|fix|release|hotfix)
            if [ -z "$TYPE" ]; then TYPE="$1"; else NAME="$1"; fi ;;
        -h|--help)
            cat <<EOF
Usage : git start [feature|fix|release|hotfix] <name> [--target <base>]
EOF
            exit 0 ;;
        *)
            if [ -z "$NAME" ]; then NAME="$1"; else die "Argument inconnu : $1"; fi ;;
    esac
    shift
done

[ -z "$TYPE" ] || [ -z "$NAME" ] && die "Usage : git start [feature|fix|release|hotfix] <name>"

case "$TYPE" in
    feature|fix)  BASE="$BASE_DEV";  BRANCH="$TYPE/$NAME" ;;
    release)      BASE="$BASE_DEV";  BRANCH="devops/$NAME" ;;
    hotfix)       BASE="$BASE_PROD"; BRANCH="$TYPE/$NAME" ;;
    *)            die "Type non reconnu : $TYPE" ;;
esac

[ -n "$TARGET_OVERRIDE" ] && BASE="$TARGET_OVERRIDE"

git fetch origin
git rev-parse --verify "$BASE" >/dev/null 2>&1 || git checkout -b "$BASE" "origin/$BASE"
git checkout "$BASE"
git pull origin "$BASE"
git switch -c "$BRANCH"
git push -u origin "$BRANCH"

ok "Branche '$BRANCH' créée depuis '$BASE' et poussée."
