#!/usr/bin/env bash
# git-wswitch
#   Liste les worktrees et en retourne un via un sélecteur interactif.
#   Affiche SEULEMENT le chemin absolu sur stdout (les logs vont sur stderr),
#   pour que la shell function `wsw` puisse faire `cd "$(git wswitch)"`.

set -euo pipefail
source "$(dirname "$(readlink -f "$0")")/../lib/wt-common.sh"

require_git_repo

# On lit git worktree list --porcelain et on formate en tableau.
# Colonnes : index, branch, path
mapfile -t lines < <(git worktree list --porcelain)

declare -a paths=() branches=() labels=()
path="" branch=""

flush() {
    [ -z "$path" ] && return 0
    local b="${branch#refs/heads/}"
    [ -z "$b" ] && b="(detached)"
    paths+=("$path")
    branches+=("$b")
    # label affiché
    local here=""
    [ "$path" = "$(pwd -P 2>/dev/null)" ] && here=" ${C_DIM}(ici)${C_RESET}"
    labels+=("$(printf '%s%-30s%s  %s%s%s%s' "$C_CYAN" "$b" "$C_RESET" "$C_DIM" "$path" "$C_RESET" "$here")")
    path=""; branch=""
}

for line in "${lines[@]}"; do
    case "$line" in
        worktree\ *)  flush; path="${line#worktree }" ;;
        branch\ *)    branch="${line#branch }" ;;
        detached)     branch="" ;;
        "")           flush ;;
    esac
done
flush

[ "${#paths[@]}" -eq 0 ] && die "Aucun worktree trouvé."
if [ "${#paths[@]}" -eq 1 ]; then
    warn "Un seul worktree : ${paths[0]}"
    printf '%s\n' "${paths[0]}"
    exit 0
fi

# Affichage numéroté sur stderr (l'utilisateur voit), stdout = chemin choisi
printf '%sWorktrees disponibles :%s\n' "$C_BOLD" "$C_RESET" >&2
for i in "${!labels[@]}"; do
    printf '  %2d) %s\n' $((i+1)) "${labels[$i]}" >&2
done
printf '\n%s→ Numéro :%s ' "$C_BOLD" "$C_RESET" >&2
read -r idx
[[ "$idx" =~ ^[0-9]+$ ]] || die "Choix invalide."
(( idx >= 1 && idx <= ${#paths[@]} )) || die "Hors limites."

selected="${paths[$((idx-1))]}"
info "→ ${branches[$((idx-1))]}  ($selected)"
printf '%s\n' "$selected"
