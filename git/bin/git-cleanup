#!/usr/bin/env bash
# git-cleanup
#   Cleanup intelligent : supprime les branches mergées dans la branche
#   par défaut OU non touchées depuis 3 mois.
#   Protège : main, develop, master, release/*.

set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/../lib/wt-common.sh"

show_help() {
    cat <<'EOF'
Usage: git cleanup

Delete local branches that are:
  - Merged into the default branch, OR
  - Not touched in 3+ months

Protected branches: main, master, develop, release/*
EOF
}

case "${1:-}" in -h|--help) show_help; exit 0 ;; esac

require_git_repo
git fetch origin --prune

cutoff=$(date -d "3 months ago" +%s)
current=$(git branch --show-current)

# Détection de la branche par défaut
default=$(git remote show origin 2>/dev/null | sed -n "/HEAD branch/s/.*: //p") || default=""
case "$default" in
    ""|"(unknown)"|"origin") default=develop ;;
esac
git show-ref --verify --quiet "refs/remotes/origin/$default" || default=develop
info "Branche de référence : $default  (cutoff = 3 mois)"

PROTECTED_RE='^(main|master|develop|release/.*)$'

# --- Branches locales -----------------------------------------
for b in $(git for-each-ref --format='%(refname:short)' refs/heads); do
    [ "$b" = "$current" ] && continue
    [[ "$b" =~ $PROTECTED_RE ]] && continue

    merged=0
    git merge-base --is-ancestor "$b" "origin/$default" 2>/dev/null && merged=1

    last=$(git log -1 --format=%ct "$b" 2>/dev/null || echo 0)
    stale=0
    [ "$last" -lt "$cutoff" ] && stale=1

    if [ "$merged" -eq 1 ] || [ "$stale" -eq 1 ]; then
        reason=""
        [ "$merged" -eq 1 ] && reason="mergée"
        [ "$stale" -eq 1 ]  && reason="${reason:+$reason, }inactive depuis 3 mois"
        info "Suppression locale '$b' ($reason)"
        git branch -D "$b" || true
        git push origin --delete "$b" 2>/dev/null || true
    fi
done

# --- Branches distantes ---------------------------------------
for rb in $(git for-each-ref --format='%(refname:short)' refs/remotes/origin | sed 's#^origin/##'); do
    [ "$rb" = "HEAD" ]     && continue
    [ "$rb" = "origin" ]   && continue
    [ "$rb" = "$default" ] && continue
    [[ "$rb" =~ $PROTECTED_RE ]] && continue

    merged=0
    git merge-base --is-ancestor "origin/$rb" "origin/$default" 2>/dev/null && merged=1

    last=$(git log -1 --format=%ct "origin/$rb" 2>/dev/null || echo 0)
    stale=0
    [ "$last" -lt "$cutoff" ] && stale=1

    if [ "$merged" -eq 1 ] || [ "$stale" -eq 1 ]; then
        info "Suppression distante 'origin/$rb'"
        git push origin --delete "$rb" 2>/dev/null || true
    fi
done

ok "Cleanup terminé."
