#!/usr/bin/env bash
# git-wip-fixup
#   Rebase interactif --autosquash jusqu'au dernier commit non-WIP.
#   Utile pour écraser toute une série de "wip", "chore: wip" etc.

set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/../lib/wt-common.sh"

require_git_repo

# Walk back from HEAD to find the first non-WIP commit.
# WIP patterns: messages starting with "WIP", "wip", "chore: wip"
first_non_wip=""
while IFS= read -r line; do
    hash="${line%% *}"
    msg="${line#* }"
    case "$msg" in
        WIP*|wip*|"chore: wip"*|"chore: WIP"*)
            continue ;;
        *)
            first_non_wip="$hash"
            break ;;
    esac
done < <(git log --pretty=format:'%h %s')

[ -z "$first_non_wip" ] && die "Aucun commit non-WIP trouvé. Impossible de squash."

# Count how many WIP commits are above it
wip_count=$(git rev-list --count "$first_non_wip..HEAD")
[ "$wip_count" -eq 0 ] && die "Aucun commit WIP au-dessus de '$first_non_wip'. Rien à squash."

info "$wip_count commit(s) WIP au-dessus de $(git log -1 --pretty='%h %s' "$first_non_wip")"
git rebase -i --autosquash "$first_non_wip"
