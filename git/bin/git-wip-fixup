#!/usr/bin/env bash
# git-wip-fixup
#   Rebase interactif --autosquash jusqu'au dernier commit non-WIP.
#   Utile pour écraser toute une série de "wip", "chore: wip" etc.

set -euo pipefail
source "$(dirname "$(readlink -f "$0")")/../lib/wt-common.sh"

require_git_repo

first_non_wip=$(git log --grep='^WIP' --invert-grep --pretty=format:'%h' | tail -n 1)
[ -z "$first_non_wip" ] && die "Aucun commit non-WIP trouvé. Impossible de squash."

first_message=$(git log -1 --pretty=%s "$first_non_wip")
if echo "$first_message" | grep -q '^WIP'; then
    warn "Le premier commit cible est un WIP. Renomme-le avant de continuer :"
    git show -s --format='%h %s' "$first_non_wip"
    exit 1
fi

git rebase -i --autosquash "$first_non_wip^"
