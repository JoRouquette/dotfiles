#!/usr/bin/env bash
# git-csharpier
#   Formate tous les fichiers .cs staged avec CSharpier puis les re-stage.

set -euo pipefail

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cs$' || true)

if [ -z "$files" ]; then
    exit 0
fi

echo "$files" | xargs dotnet csharpier
echo "$files" | xargs git add
