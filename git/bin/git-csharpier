#!/usr/bin/env bash
# git-csharpier
#   Formate tous les fichiers .cs staged avec CSharpier puis les re-stage.

set -euo pipefail

show_help() {
    cat <<'EOF'
Usage: git csharpier

Format all staged .cs files with CSharpier and re-stage them.
EOF
}

case "${1:-}" in -h|--help) show_help; exit 0 ;; esac

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.cs$' || true)

if [ -z "$files" ]; then
    exit 0
fi

echo "$files" | xargs dotnet csharpier
echo "$files" | xargs git add
