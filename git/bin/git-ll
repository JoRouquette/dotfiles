#!/usr/bin/env bash
# git-ll <n>
#   Log des <n> derniers commits avec le message complet (body),
#   format lisible : hash cyan, date, auteur, puis le message.

set -euo pipefail

show_help() {
    cat <<'EOF'
Usage: git ll <n>

Show last <n> commits with full message body.

Examples:
  git ll 5
  git ll 10
EOF
}

case "${1:-}" in -h|--help) show_help; exit 0 ;; esac

if [ $# -eq 0 ]; then
    echo "Usage : git ll <number>" >&2
    exit 1
fi

git log -n "$1" \
    --pretty=format:'%C(yellow)%h%Creset %C(cyan)%ad%Creset %Cgreen%an%Creset%n%B' \
    --date=short
