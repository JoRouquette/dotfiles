#!/usr/bin/env bash
# git-prgithub [-t <titre>] [--target <branche>] [--draft]
#   Crée une PR GitHub via `gh` et l'ouvre dans le navigateur.

set -euo pipefail
source "$(dirname "$(readlink -f "$0")")/../lib/wt-common.sh"

if [ "${1:-}" = "--help" ]; then
    cat <<EOF
Usage : git prgithub [-t <titre>] [--target <branche>] [--draft]
EOF
    exit 0
fi

command -v gh >/dev/null || die "La CLI GitHub 'gh' n'est pas installée."

TARGET=""; TITLE=""; DRAFT_OPTION=""
while [ $# -gt 0 ]; do
    case "$1" in
        -t)        shift; TITLE="$1" ;;
        --target)  shift; TARGET="$1" ;;
        --draft)   DRAFT_OPTION="--draft" ;;
    esac
    shift
done

require_git_repo
BR=$(git rev-parse --abbrev-ref HEAD)
SHORT_NAME="${BR##*/}"
PREFIX="${BR%%/*}"

if [ -z "$TARGET" ]; then
    case "$PREFIX" in
        feature|feat|fix)  TARGET="develop" ;;
        release|hotfix)    TARGET="main" ;;
        *)                 die "Type de branche non reconnu : $PREFIX" ;;
    esac
fi

FINAL_TITLE="${TITLE:-$SHORT_NAME}"

gh pr create --head "$BR" --base "$TARGET" --title "$FINAL_TITLE" $DRAFT_OPTION --web \
    && ok "PR créée (ouverte dans le navigateur)." \
    || die "Échec de la création de la PR."
