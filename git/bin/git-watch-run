#!/usr/bin/env bash
# git-watch-run [--target <t>] [--connection <c>]
#   Sélectionne un projet .csproj et lance `dotnet watch run` en boucle.

set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/../lib/wt-common.sh"

case "${1:-}" in
    -h|--help)
        cat <<EOF
Usage : git watch-run [--target <target>] [--connection <connection>]
EOF
        exit 0 ;;
esac

TARGET=""; CONNECTION=""
while [ $# -gt 0 ]; do
    case "$1" in
        --target)       shift; TARGET="$1" ;;
        --connection)   shift; CONNECTION="$1" ;;
        *)              break ;;
    esac
    shift
done

mapfile -t PROJECTS < <(find . -name '*.csproj' | sed 's|^./||')
[ "${#PROJECTS[@]}" -eq 0 ] && die "Aucun .csproj trouvé."

PROJECT=$(pick_from_list "Projets disponibles :" "${PROJECTS[@]}")

args=(dotnet watch run --project "$PROJECT")
[ -n "$CONNECTION" ] && args+=(--connection "$CONNECTION")
[ -n "$TARGET" ]     && args+=(--target "$TARGET")

info "Démarrage : $PROJECT"
while true; do
    info "Exécution : ${args[*]}"
    "${args[@]}" || true
    warn "Redémarrage dans 5 secondes... (Ctrl+C pour arrêter)"
    sleep 5
done
